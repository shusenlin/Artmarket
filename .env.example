# =============================================================================
# 艺术品展示与交易网站 - 环境变量配置模板
# 复制此文件为 .env 并填写实际值，切勿将 .env 提交到版本控制
# =============================================================================

# -----------------------------------------------------------------------------
# Flask 应用配置
# -----------------------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# -----------------------------------------------------------------------------
# 数据库配置 (开发环境使用 SQLite, 生产环境使用 PostgreSQL)
# -----------------------------------------------------------------------------
# 开发环境 (SQLite):
DATABASE_URL=sqlite:///./instance/artmarket.db

# 生产环境 (PostgreSQL) 示例:
# DATABASE_URL=postgresql://username:password@localhost:5432/artmarket_db

# SQLAlchemy 配置
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ENGINE_OPTIONS={"pool_pre_ping": true, "pool_recycle": 3600}

# -----------------------------------------------------------------------------
# 阿里云 OSS 配置 (用于艺术品图片/视频存储)
# -----------------------------------------------------------------------------
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BASE_URL=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com

# OSS 路径配置
OSS_ARTWORKS_FOLDER=artworks/
OSS_THUMBNAILS_FOLDER=thumbnails/

# -----------------------------------------------------------------------------
# 文件上传配置
# -----------------------------------------------------------------------------
MAX_CONTENT_LENGTH=52428800  # 50MB 最大上传限制
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif,webp,mp4,webm

# -----------------------------------------------------------------------------
# 火山方舟智能体配置
# -----------------------------------------------------------------------------
ARK_API_KEY=your-volcengine-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-2-0-pro-260215

# -----------------------------------------------------------------------------
# 邮件配置 (可选，用于用户注册/通知)
# -----------------------------------------------------------------------------
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 时区设置
TIMEZONE=Asia/Singapore

# 分页配置
ITEMS_PER_PAGE=20
